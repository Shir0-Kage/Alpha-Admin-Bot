# Copy this to .env and fill in your values. .env is git-ignored, never commit it.

# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF_your_telegram_bot_token_here

# chat/topic routing as JSON: friendly name -> chat id + (optional) topic thread id
# grab the ids from @userinfobot or the bot api
CHAT_CONFIG={"STR RPT": {"CHAT_ID": -1001234567890, "THREAD_ID": 2}, "BOT UPDATES": {"CHAT_ID": -1001234567890, "THREAD_ID": 5}}

# which CHAT_CONFIG keys the scheduled tasks post to
STR_RPT_CHAT=STR RPT
BOT_UPDATES_CHAT=BOT UPDATES

# google service account json (enable the Sheets API, then share each sheet with its email)
GOOGLE_SERVICE_ACCOUNT_FILE=./service_account.json

# the three sheets. point all three at the same url if you use one spreadsheet.
# run "python init_sheets.py" to generate fresh templates
PARADESTATE_SHEET_URL=https://docs.google.com/spreadsheets/d/your_paradestate_sheet_id/edit
COMMANDER_DUTY_SHEET_URL=https://docs.google.com/spreadsheets/d/your_commander_duty_sheet_id/edit
TROOPER_DUTY_SHEET_URL=https://docs.google.com/spreadsheets/d/your_trooper_duty_sheet_id/edit

# prefix for generated soldier ids, e.g. 3SIR19A -> 3SIR19A-ZHOUZE01
UNIT_ID_HEADER=3SIR19A

# sqlite db file
DB_PATH=./alpha.db

# DEBUG / INFO / WARNING / ERROR / CRITICAL
LOG_LEVEL=INFO
